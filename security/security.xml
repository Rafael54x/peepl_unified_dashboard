<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================== -->
    <!-- USER GROUPS                                -->
    <!-- ========================================== -->
    
    <record id="module_category_hr_dashboard" model="ir.module.category">
        <field name="name">HR Dashboard</field>
        <field name="description">Manage access to HR dashboard features</field>
        <field name="sequence">26</field>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_hr_dashboard">
        <field name="name">HR Dashboard</field>
        <field name="sequence">1</field>
        <field name="category_id" ref="module_category_hr_dashboard"/>
    </record>

    <record id="group_hr_dashboard_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_dashboard"/>
        <field name="comment">User can access their own data</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_hr_dashboard_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_dashboard"/>
        <field name="comment">Manager can access department data</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_hr_dashboard_all_access" model="res.groups">
        <field name="name">All Access</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_dashboard"/>
        <field name="comment">Can access all data</field>
        <field name="sequence">30</field>
    </record>

    <data noupdate="0">
        <!-- IR Rule: User can read all records, filtering done in JS -->
        <record id="hr_version_rule_dashboard_user" model="ir.rule">
            <field name="name">Dashboard User: Read all contracts</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_dashboard_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="hr_version_rule_dashboard_manager" model="ir.rule">
            <field name="name">Dashboard Manager: Full access to contracts</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_dashboard_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="hr_version_rule_dashboard_all_access" model="ir.rule">
            <field name="name">Dashboard All Access: Full access to contracts</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_dashboard_all_access'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="hr_version_rule_admin" model="ir.rule">
            <field name="name">Admin: Full access to contracts</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="hr_attendance_rule_dashboard_user" model="ir.rule">
            <field name="name">Dashboard User: Read all attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_dashboard_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="hr_attendance_rule_dashboard_manager" model="ir.rule">
            <field name="name">Dashboard Manager: Full access to attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_dashboard_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="hr_attendance_rule_dashboard_all_access" model="ir.rule">
            <field name="name">Dashboard All Access: Full access to attendance</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_dashboard_all_access'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>

</odoo>