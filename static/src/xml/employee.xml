<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="peepl_unified_dashboard.Employee">
        <div class="peepl-dashboard-container" style="margin-bottom: 40px;">
            <div class="peepl-employee-page">
                <!-- Header Section -->
                <div class="peepl-employee-header">
                    <div class="peepl-employee-header-left">
                        <div class="peepl-employee-icon-wrapper peepl-bg-blue-50">
                            <i class="fa fa-users peepl-text-blue-500"/>
                        </div>
                        <div>
                            <h1 class="peepl-employee-title">Employee Directory</h1>
                            <p class="peepl-employee-subtitle">
                                <t t-if="state.isHRDashboardUserOnly">Your Profile</t>
                                <t t-if="state.isHRDashboardManager and !state.isHRDashboardUserOnly">Department Employees</t>
                                <t t-if="!state.isHRDashboardUserOnly and !state.isHRDashboardManager">All Employees</t>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Search and Filter Section -->
                <div class="peepl-employee-controls">
                    <div class="peepl-search-box">
                        <i class="fa fa-search"/>
                        <input 
                            type="text" 
                            class="peepl-search-input"
                            placeholder="Search by name, email, or position..."
                            t-model="state.searchQuery"
                        />
                    </div>

                    <t t-if="state.isHRDashboardAllAccess">
                        <div class="peepl-department-filter">
                            <button class="peepl-filter-btn peepl-filter-all" t-on-click="() => this.handleDepartmentFilter(null)">
                                <i class="fa fa-filter"/>
                                All Departments
                            </button>
                            <t t-foreach="state.allDepartments" t-as="dept" t-key="dept.id">
                                <button 
                                    t-attf-class="peepl-filter-btn {{state.filterDepartment === dept.id ? 'peepl-filter-active' : ''}}"
                                    t-on-click="() => this.handleDepartmentFilter(dept.id)"
                                    t-esc="dept.name"
                                />
                            </t>
                        </div>
                    </t>
                </div>

                <!-- Employee Grid Section -->
                <div class="peepl-employee-grid">
                    <t t-if="getFilteredEmployees().length > 0" t-foreach="getFilteredEmployees()" t-as="employee" t-key="employee.id">
                        <div class="peepl-employee-card" t-on-click="() => this.openEmployeeModal(employee)" style="cursor: pointer;">
                            <!-- Avatar Section -->
                            <div class="peepl-employee-card-header">
                                <t t-if="employee.image">
                                    <img t-attf-src="{{employee.image}}" class="peepl-employee-avatar" t-attf-alt="{{employee.name}}"/>
                                </t>
                                <t t-if="!employee.image">
                                    <div class="peepl-employee-avatar-placeholder" t-esc="employee.initials"/>
                                </t>
                                <div class="peepl-employee-status"></div>
                            </div>

                            <!-- Employee Info Section -->
                            <div class="peepl-employee-card-body">
                                <h3 class="peepl-employee-name" t-esc="employee.name"/>
                                <p class="peepl-employee-job-title" t-esc="employee.jobTitle"/>
                                <p class="peepl-employee-department">
                                    <i class="fa fa-building"/> <span t-esc="employee.department"/>
                                </p>
                            </div>

                            <!-- Contact Section -->
                            <div class="peepl-employee-card-footer">
                                <a t-attf-href="mailto:{{employee.email}}" class="peepl-contact-link peepl-email-link" t-attf-title="{{employee.email}}" t-on-click.stop="">
                                    <i class="fa fa-envelope"/>
                                </a>
                                <a t-attf-href="tel:{{employee.phone}}" class="peepl-contact-link peepl-phone-link" t-attf-title="{{employee.phone}}" t-if="employee.phone !== '-'" t-on-click.stop="">
                                    <i class="fa fa-phone"/>
                                </a>
                            </div>
                        </div>
                    </t>
                    <t t-if="getFilteredEmployees().length === 0">
                        <div class="peepl-employee-empty">
                            <i class="fa fa-inbox"/>
                            <h3>No Employees Found</h3>
                            <p>Try adjusting your search or filter criteria.</p>
                        </div>
                    </t>
                </div>

                <!-- Employee Modal -->
                <t t-if="state.selectedEmployee">
                    <div class="peepl-modal-overlay" t-on-click="() => this.closeEmployeeModal()">
                        <div class="peepl-modal-content" t-on-click.stop="">
                            <div class="peepl-modal-header">
                                <h2>Employee Information</h2>
                                <button class="peepl-modal-close" t-on-click="() => this.closeEmployeeModal()">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                            <div class="peepl-modal-body">
                                <div class="peepl-employee-info-grid">
                                    <div class="peepl-info-item">
                                        <label>Name</label>
                                        <p t-esc="state.selectedEmployee.name"/>
                                    </div>
                                    <div class="peepl-info-item">
                                        <label>Email</label>
                                        <p t-esc="state.selectedEmployee.email"/>
                                    </div>
                                    <div class="peepl-info-item">
                                        <label>Phone</label>
                                        <p t-esc="state.selectedEmployee.phone"/>
                                    </div>
                                    <div class="peepl-info-item">
                                        <label>Department</label>
                                        <p t-esc="state.selectedEmployee.department"/>
                                    </div>
                                    <div class="peepl-info-item">
                                        <label>Job Title</label>
                                        <p t-esc="state.selectedEmployee.jobTitle"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Stats Section -->
                <div class="peepl-employee-stats">
                    <div class="peepl-stat-card">
                        <div class="peepl-stat-value" t-esc="getFilteredEmployees().length"/>
                        <div class="peepl-stat-label">
                            <t t-if="state.isHRDashboardUserOnly">You</t>
                            <t t-if="state.isHRDashboardManager and !state.isHRDashboardUserOnly">Team Members</t>
                            <t t-if="!state.isHRDashboardUserOnly and !state.isHRDashboardManager">Employees</t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
