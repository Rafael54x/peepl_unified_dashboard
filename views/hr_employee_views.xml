<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_payroll_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.payroll.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='payroll_information']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
    
    <record id="view_employee_form_dashboard_user" model="ir.ui.view">
        <field name="name">hr.employee.form.dashboard.user</field>
        <field name="model">hr.employee</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form string="Employee" duplicate="false" create="false" edit="false" delete="false">
                <sheet>
                    <div class="row flex-column flex-sm-row align-items-center">
                        <div class="o_employee_avatar ms-2 p-0 h-100 mw-25 align-self-start align-self-sm-center">
                            <field name="image_1920" widget="image" class="m-0" options="{&quot;size&quot;: [128,158], &quot;zoom&quot;: true, &quot;preview_image&quot;:&quot;avatar_128&quot;}" readonly="1"/>
                        </div>
                        <div class="align-self-start o_employee_form_header_info">
                            <div class="oe_title ps-0 pe-2 mw-100">
                                <h1 class="d-flex flex-row align-items-center">
                                    <field name="name" readonly="1" style="font-size: min(4vw, 2.6rem);"/>
                                </h1>
                                <h5 class="d-flex align-items-baseline mb-0">
                                    <i class="fa fa-envelope fa-fw me-1 text-primary" title="Work Email"/>
                                    <field name="work_email" widget="email" readonly="1"/>
                                </h5>
                                <h5 class="d-flex align-items-baseline mb-0">
                                    <i class="fa fa-phone fa-fw me-1 text-primary" title="Work Phone"/>
                                    <field name="work_phone" widget="phone" readonly="1"/>
                                </h5>
                                <h5 class="d-flex align-items-baseline mb-0">
                                    <i class="fa fa-mobile fa-fw me-1 text-primary" title="Work Mobile"/>
                                    <field name="mobile_phone" widget="phone" readonly="1"/>
                                </h5>
                            </div>
                        </div>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="employee_properties" columns="2" readonly="1"/>
                    <notebook>
                        <page name="work_information" string="Work">
                            <div class="row">
                                <div class="col-lg-7">
                                    <group string="Work">
                                        <field name="company_id" readonly="1"/>
                                        <field name="department_id" readonly="1"/>
                                        <field name="job_id" readonly="1"/>
                                        <field name="job_title" readonly="1"/>
                                        <field name="parent_id" widget="many2one_avatar_employee" readonly="1"/>
                                    </group>
                                    <group string="Location">
                                        <field name="address_id" readonly="1"/>
                                        <field name="work_location_id" readonly="1"/>
                                    </group>
                                </div>
                            </div>
                        </page>
                        <page name="resume" string="Resume">
                            <div class="row">
                                <div class="col-lg-7">
                                    <group>
                                        <field name="certificate" readonly="1"/>
                                        <field name="study_field" readonly="1"/>
                                    </group>
                                </div>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_employee_dashboard_user" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_employee_form_dashboard_user"/>
        <field name="context">{}</field>
    </record>
</odoo>
