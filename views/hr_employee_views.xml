<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_payroll_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.payroll.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='payroll_information']" position="attributes">
                <attribute name="groups">peepl_unified_dashboard.group_hr_dashboard_user</attribute>
            </xpath>
        </field>
    </record>
    
    <record id="view_employee_form_readonly" model="ir.ui.view">
        <field name="name">hr.employee.form.readonly</field>
        <field name="model">hr.employee</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <field name="work_email" readonly="1"/>
                        <field name="work_phone" readonly="1"/>
                        <field name="mobile_phone" readonly="1"/>
                        <field name="department_id" readonly="1"/>
                        <field name="job_title" readonly="1"/>
                        <field name="birthday" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
