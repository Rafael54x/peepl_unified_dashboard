<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Holiday Type List View -->
    <record id="view_holiday_type_list" model="ir.ui.view">
        <field name="name">holiday.type.list</field>
        <field name="model">holiday.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <!-- Holiday Type Form View -->
    <record id="view_holiday_type_form" model="ir.ui.view">
        <field name="name">holiday.type.form</field>
        <field name="model">holiday.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Holiday Type Action -->
    <record id="action_holiday_type" model="ir.actions.act_window">
        <field name="name">Holiday Types</field>
        <field name="res_model">holiday.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Holiday Type Menu -->
    <menuitem id="menu_holiday_type"
              name="Holiday Types"
              parent="hr_holidays.menu_hr_holidays_configuration"
              action="action_holiday_type"
              groups="hr_holidays.group_hr_holidays_manager"
              sequence="3"/>

    <!-- Extend Resource Calendar Leaves List View -->
    <record id="view_resource_calendar_leaves_list_inherit" model="ir.ui.view">
        <field name="name">resource.calendar.leaves.list.inherit</field>
        <field name="model">resource.calendar.leaves</field>
        <field name="inherit_id" ref="hr_holidays.resource_calendar_leaves_tree_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_entry_type_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='calendar_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <field name="work_entry_type_id" position="after">
                <field name="holiday_type_id"/>
            </field>
        </field>
    </record>

    <!-- Extend Resource Calendar Leaves Form View -->
    <record id="view_resource_calendar_leaves_form_inherit" model="ir.ui.view">
        <field name="name">resource.calendar.leaves.form.inherit</field>
        <field name="model">resource.calendar.leaves</field>
        <field name="inherit_id" ref="resource.resource_calendar_leave_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="holiday_type_id"/>
            </field>
        </field>
    </record>
</odoo>